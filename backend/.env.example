# Backend server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/hanria_ecotech

# Admin auth
# This is the key you will enter in the Admin page to login.
ADMIN_KEY=change_this_admin_key

# JWT
JWT_SECRET=change_this_jwt_secret

# CORS (comma-separated). For Vite dev typically http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# SMTP configuration
# If you use Gmail, prefer an App Password.
# Minimal Gmail setup supported by this backend:
#   SMTP_USER=your.email@gmail.com
#   SMTP_PASS=your_app_password
# You may also use SMTP_PASSWORD or (typo) SMPT_PASSWORD as the password key.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password

# Mail routing
# If omitted, MAIL_TO and MAIL_FROM default to SMTP_USER.
MAIL_TO=info@hanriaecotech.com
MAIL_FROM=HanRia Eco Tech <no-reply@hanriaecotech.com>

# Uploads
# Set to cloudinary to store uploads in Cloudinary (no local /uploads writes).
# Set to local to store uploads under backend/uploads.
UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hanria-ecotech
